{
  "autoUpdatesChannel": "latest",
  "env": { "ENABLE_LSP_TOOL": "1" },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(npm test)",
      "Bash(sed *)"
    ]
  }
}
